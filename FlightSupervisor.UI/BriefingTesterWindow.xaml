<Window x:Class="FlightSupervisor.UI.BriefingTesterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Briefing Simulator" Height="600" Width="800" Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="METAR / TAF Code Breaker" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Foreground="#007ACC"/>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Raw METAR:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                <TextBox x:Name="MetarInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Background="#333333" Foreground="White" Padding="5"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2">
                <TextBlock Text="Raw TAF (Optional):" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                <TextBox x:Name="TafInput" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Background="#333333" Foreground="White" Padding="5"/>
            </StackPanel>
        </Grid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Randomize Weather" Height="40" Width="180" Background="#8B0000" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,20,0" Click="GenerateRandomWeather_Click"/>
            <Button Content="Generate Briefing Analysis" Height="40" Width="250" Background="#007ACC" Foreground="White" FontWeight="Bold" FontSize="14" Click="GenerateButton_Click"/>
        </StackPanel>
        
        <TextBox x:Name="OutputText" Grid.Row="3" Background="#111111" Foreground="#00FF00" FontFamily="Consolas" FontSize="15" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" Padding="10"/>
    </Grid>
</Window>
