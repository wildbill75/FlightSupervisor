<Window x:Class="FlightSupervisor.UI.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Developer &amp; Connected Tools" Height="500" Width="700"
        Background="#141414" Foreground="White" WindowStyle="ToolWindow" Topmost="True" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Connected Tools -->
        <Border Grid.Row="0" Background="#1A1e2e" BorderBrush="#3b82f6" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="CONNECTED TOOLS (MSFS Time Warp)" Foreground="#60a5fa" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Fast Forward jumps Zulu time by the set amount to skip turnaround waiting." Foreground="#94a3b8" FontSize="11" Margin="0,0,0,15" TextWrapping="Wrap"/>
                
                <UniformGrid Columns="3" Rows="1">
                    <Button Content="FAST FORWARD +5m" Background="#0f172a" Foreground="#60a5fa" BorderBrush="#3b82f6" BorderThickness="1" Margin="5" Padding="10" Click="BtnFastForward5_Click"/>
                    <Button Content="FAST FORWARD +10m" Background="#0f172a" Foreground="#60a5fa" BorderBrush="#3b82f6" BorderThickness="1" Margin="5" Padding="10" Click="BtnFastForward10_Click"/>
                    <Button Content="FAST FORWARD +20m" Background="#0f172a" Foreground="#60a5fa" BorderBrush="#3b82f6" BorderThickness="1" Margin="5" Padding="10" Click="BtnFastForward20_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>

        <!-- Dev Tools -->
        <Border Grid.Row="1" Background="#3f1222" BorderBrush="#e11d48" BorderThickness="1" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="DEV TOOLS (Phase Sim Offline)" Foreground="#fb7185" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Force phase transitions offline. WARNING: Do not use while connected to MSFS." Foreground="#94a3b8" FontSize="11" Margin="0,0,0,15" TextWrapping="Wrap"/>
                
                <UniformGrid Columns="3" Rows="3">
                    <Button Content="TRIGGER ARRIVAL (START TURNAROUND)" Background="#1e1b4b" Foreground="#a78bfa" BorderBrush="#8b5cf6" BorderThickness="2" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Turnaround"/>
                    <Button Content="FORCE BOARDING" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Boarding"/>
                    <Button Content="FORCE PUSHBACK" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Pushback"/>
                    <Button Content="FORCE TAKEOFF" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Takeoff"/>
                    <Button Content="FORCE CRUISE" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Cruise"/>
                    <Button Content="FORCE DESCENT" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Descent"/>
                    <Button Content="FORCE ARRIVED" Background="#0f172a" Foreground="#fb7185" BorderBrush="#e11d48" BorderThickness="1" Margin="5" Padding="10" Click="BtnForcePhase_Click" Tag="Arrived"/>
                    <Button Content="COMPLETE ACTIVE OPS" Background="#064e3b" Foreground="#34d399" BorderBrush="#059669" BorderThickness="2" Margin="5" Padding="10" Click="BtnCompleteOps_Click"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
