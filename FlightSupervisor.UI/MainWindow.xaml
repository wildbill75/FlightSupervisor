<Window x:Class="FlightSupervisor.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Flight Supervisor"
        Height="768" Width="1200"
        WindowStyle="None"
        Background="#0F111A"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Border Background="#0F111A" BorderThickness="1" BorderBrush="#3F4C5E" Margin="3">
        <Grid>
            <wv2:WebView2 x:Name="MainWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        </Grid>
    </Border>
</Window>
